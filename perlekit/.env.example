# Perle Command Center — Environment Variables
# This app uses no secret API keys.
# CoinGecko public API requires no key.
# Copy this file to .env and fill in if needed in future.

# Optional: Override CoinGecko endpoint if you have a pro key
# VITE_COINGECKO_URL=https://api.coingecko.com/api/v3/simple/price
